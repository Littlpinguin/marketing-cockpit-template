{
  "mcpServers": {
    "n8n-mcp": {
      "command": "npx",
      "args": ["n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "https://VOTRE_INSTANCE_N8N/api/v1",
        "N8N_API_KEY": "VOTRE_CLE_API_N8N",
        "WEBHOOK_SECURITY_MODE": "moderate"
      }
    }
  }
}
